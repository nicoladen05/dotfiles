set sandbox none
set statusbar-h-padding 0
set statusbar-v-padding 0
set page-padding 1
set selection-clipboard clipboard
map u scroll half-up
map d scroll half-down
map D toggle_page_mode
map r reload
map R rotate
map K zoom in
map J zoom out
map i recolor
map p print

set recolor   
set recolor-lightcolor \#1C1E27
set recolor-keephue
set default-bg \#1C1E27
set statusbar-bg                "#1C1E27"
set inputbar-bg                 "#1C1E22"
