configuration {
	modi: "run,window,ssh";
	font: "Terminus 10";
	sidebar-mode: true;
	combi-modi: "window,drun";
	hide-scrollbar: true;
	theme: "slate";
	kb-mode-next: "Alt+Right,Shift+Right,Control+Tab";
	kb-mode-previous: "Alt+Left,Shift+Left,Control+ISO_Left_Tab";
	kb-row-select: "";
	kb-cancel: "Escape,Control+bracketleft";
}
